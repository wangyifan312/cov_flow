{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "coverage_gap.schema.json",
  "title": "Coverage Gap",
  "description": "A single coverage gap extracted from a coverage report.",
  "type": "object",
  "required": [
    "gap_id",
    "coverage_type",
    "hit_count",
    "goal"
  ],
  "additionalProperties": false,
  "properties": {
    "gap_id": {
      "type": "string",
      "description": "Stable unique identifier for this gap.",
      "pattern": "^GAP_(?:[A-Z][0-9]{3}|[0-9]{4})$"
    },
    "coverage_type": {
      "type": "string",
      "enum": ["functional", "line", "toggle", "branch", "condition", "fsm", "assert"],
      "description": "Type of coverage."
    },
    "covergroup": {
      "type": "string",
      "description": "Name of the covergroup containing this gap."
    },
    "coverpoint": {
      "type": "string",
      "description": "Name of the coverpoint containing this gap."
    },
    "bin": {
      "type": "string",
      "description": "Name of the uncovered bin."
    },
    "hit_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Current hit count for this bin."
    },
    "goal": {
      "type": "integer",
      "minimum": 1,
      "description": "Target hit count for this bin."
    },
    "source_file": {
      "type": "string",
      "description": "Path to the coverage model source file."
    },
    "source_line": {
      "type": "integer",
      "minimum": 1,
      "description": "Line number in the coverage model source."
    },
    "cluster_id": {
      "type": "string",
      "description": "Cluster identifier for grouping related gaps."
    },
    "classification": {
      "type": "string",
      "enum": [
        "Missing Stimulus",
        "Config Missing",
        "Constraint Too Tight",
        "Coverage Model Issue",
        "Monitor Sampling Issue",
        "Unreachable Candidate",
        "Dead Code",
        "Defensive Code",
        "Unreachable State",
        "Insufficient Toggle"
      ],
      "description": "Gap classification from triage."
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3"],
      "description": "Priority ranking."
    },
    "related_register": {
      "type": ["string", "null"],
      "description": "Register field likely controlling this gap, or null if unknown."
    },
    "related_spec_section": {
      "type": ["string", "null"],
      "description": "Relevant spec section identifier, or null if unknown."
    },
    "related_rtl_signal": {
      "type": ["string", "null"],
      "description": "Relevant RTL signal, or null if unknown."
    },
    "signal": {
      "type": "string",
      "description": "Signal name for toggle coverage."
    },
    "toggle_dir": {
      "type": "string",
      "enum": ["0to1", "1to0"],
      "description": "Toggle direction."
    },
    "module": {
      "type": "string",
      "description": "Module containing the signal or FSM."
    },
    "branch_type": {
      "type": "string",
      "enum": ["if", "else", "case", "ternary"],
      "description": "Branch construct type."
    },
    "direction": {
      "type": "string",
      "enum": ["true", "false"],
      "description": "Branch direction not taken."
    },
    "condition_expr": {
      "type": "string",
      "description": "Boolean expression being covered."
    },
    "combination": {
      "type": "string",
      "description": "Specific truth-table combination missed."
    },
    "fsm_name": {
      "type": "string",
      "description": "FSM identifier name."
    },
    "state": {
      "type": "string",
      "description": "FSM state not reached."
    },
    "transition": {
      "type": "string",
      "pattern": "^.+->.+$",
      "description": "Optional state transition (from->to)."
    },
    "assert_name": {
      "type": "string",
      "description": "Assertion name."
    },
    "fail_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of assertion failures."
    },
    "vacuous": {
      "type": "boolean",
      "description": "Whether the assertion is vacuous."
    }
  },
  "anyOf": [
    {
      "description": "Functional coverage: covergroup/coverpoint/bin",
      "properties": { "coverage_type": { "const": "functional" } },
      "required": ["covergroup", "coverpoint", "bin"]
    },
    {
      "description": "Line coverage: source_file/source_line",
      "properties": { "coverage_type": { "const": "line" } },
      "required": ["source_file", "source_line"]
    },
    {
      "description": "Branch coverage: source_file/source_line/branch_type/direction",
      "properties": { "coverage_type": { "const": "branch" } },
      "required": ["source_file", "source_line", "branch_type", "direction"]
    },
    {
      "description": "Condition coverage: source_file/source_line/condition_expr/combination",
      "properties": { "coverage_type": { "const": "condition" } },
      "required": ["source_file", "source_line", "condition_expr", "combination"]
    },
    {
      "description": "Toggle coverage: signal/toggle_dir/module",
      "properties": { "coverage_type": { "const": "toggle" } },
      "required": ["signal", "toggle_dir", "module"]
    },
    {
      "description": "FSM coverage: module/fsm_name/state",
      "properties": { "coverage_type": { "const": "fsm" } },
      "required": ["module", "fsm_name", "state"]
    },
    {
      "description": "Assert coverage: assert_name/source_file/source_line",
      "properties": { "coverage_type": { "const": "assert" } },
      "required": ["assert_name", "source_file", "source_line"]
    }
  ]
}
